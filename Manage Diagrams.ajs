/*
 * Create a header with diagram name, version, created_by, created_on, last_edited_by and last_edited_on. 
 * These values are read from and written to the diagram properties. 
 * Created by Werner Horlings
 * 
 * v1 - 2023-01-17 - Werner Horlings - Initial Concept
 * v2 - 2023-03-17 - Steven Mileham - Combined into single script to support Create/Update View
 * v2.1 - 2023-03-18 - Steven Mileham - Added sort function to View folder widget
 * v2.2 - 2023-03-20 - Steven Mileham - Added support for Exclude from Report, Global Changelog and initial Config file (WIP)
 * v2.3 - 2023-03-22 - Steven Mileham - Encorporated Clipboard Script, added basic Config Wizard
 * v2.4 - 2023-03-23 - Steven Mileham - Added support for custom colours, fixed bug on Create, refactored formatting, split Global Changelog to User Changelog.
 * v2.4.1 - 2023-03-23 - Stevem Mileham - Fixed bug in Create logic, Changed View Reference text position.
 * v2.5 - 2023-03-23 - Steven Mileham - Added initial support for Logo.
 * v2.5.1 - 2023-03-23 - Steven Mileham - Fixed bugs, replaced Logo URL with File Picker.
 * v2.5.2 - 2023-03-26 - Steven Mileham - Added options for opacity, added option to hide Link icon, added option to change height of links.
  * v2.5.3 - 2023-03-31 - Werner Horlings - Added coArchi support, default config setting based on existing config file, option to change view references only, option to linkify a logo, layout jface dialogs improved
 * 
 * Config screen made possible with script from RChevallier https://gist.github.com/rchevallier/d155527dcc3e956848a90e51bf21d7e1
 */

console.show();
console.clear();
headerConfig = {};

function buttonDialog(message,options) {
    var dialog = new org.eclipse.jface.dialogs.MessageDialog(shell,"Archi",null,message,3,options.concat(["Cancel"]),0);
    
    var result=dialog.open();
    return result==options.length?null:(result+1).toString();
}
    
function rgbToHex(r, g, b) {
    function componentToHex(c) {
        var hex = c.toString(16);
        return hex.length == 1 ? "0" + hex : hex;
    }

    return "#" + componentToHex(r) + componentToHex(g) + componentToHex(b);
}
    
function colorDialog() {
    dialog = new org.eclipse.swt.widgets.ColorDialog(shell);
    theColourRGB = dialog.open();
    return !theColourRGB?null:rgbToHex(theColourRGB.red,theColourRGB.green,theColourRGB.blue);   
}

function getLogoFile(fileSrc) {
    const StandardCopyOption = Java.type ('java.nio.file.StandardCopyOption');
    const Files = Java.type ('java.nio.file.Files');
    const FileSystems = Java.type ('java.nio.file.FileSystems');
    var theSource = FileSystems.getDefault().getPath(fileSrc);
    var theExtension = theSource.toString().substring(theSource.toString().lastIndexOf("."));
    var theTarget = FileSystems.getDefault().getPath( __DIR__ + ".conf/logo"+theExtension);

    Files.copy(theSource,theTarget, StandardCopyOption.REPLACE_EXISTING);
    return theTarget.toString();
}

function configWizard(){
	
    headerConfig.gridSize = parseInt(window.prompt("Enter size of Archi grid (default 12)",headerConfig.gridSize));
    headerConfig.wide=buttonDialog("Show header in Wide format or Tall?",["Wide","Tall"])=="1"?true:false;
    headerConfig.showChangelog = buttonDialog("Show Changelog in header?",["Yes","No"])=="1"?true:false;
	headerConfig.useCoarchi = buttonDialog("Do you use coArchi?",["Yes","No"])=="1"?true:false;
    //headerConfig.globalChangelog=buttonDialog("Add all 'Changes' to User 'Change Log' //View?",["Yes","No"])=="1"?true:false;
    //headerConfig.clipChangelog=buttonDialog("Update clipboard with contents of 'Change' after updating dialog?",["Yes","No"])=="1"?true:false;
    headerConfig.linkHeight=buttonDialog("Height of Link references (in grid squares)?",["3","2"])=="1"?3:2;
    headerConfig.showLinkIcons=buttonDialog("Show icon on links in header?",["Yes","No"])=="1"?true:false;
    headerConfig.showLogo=buttonDialog("Show Logo in Header? (Recommended Size "+headerConfig.gridSize*5+"x"+headerConfig.gridSize*19+")",["Yes","No"])=="1"?true:false;
    if (headerConfig.showLogo) {
        headerConfig.logoSource =  window.promptOpenFile({ title: "Select Logo", filterExtensions: ["*.png","*.gif","*.jpg"] });
        if (headerConfig.logoSource!=null) {
            headerConfig.logoFile=getLogoFile(headerConfig.logoSource);
        }
    }

    headerConfig.customColours = buttonDialog("Set custom header colours?",["Yes","No"])=="1"?true:false;
    if (headerConfig.customColours) {
        headerConfig.groupFillColour = window.prompt("Please choose a colour for the Header background\n(Leave blank to select via Colour picker)",headerConfig.groupFillColour);
        if (headerConfig.groupFillColour=="") {headerConfig.groupFillColour = colorDialog();}
        headerConfig.groupOpacity = window.prompt("Please set opacity for Header background\n(Default 255)",headerConfig.groupOpacity);
        headerConfig.groupOutlineOpacity = window.prompt("Please set opacity for Header border\n(Default 255)",headerConfig.groupOutlineOpacity);

        headerConfig.labelFillColour = window.prompt("Please choose a colour for the Label background\n(Leave blank to select via Colour picker)",headerConfig.labelFillColour);
        if (headerConfig.labelFillColour=="") {headerConfig.labelFillColour = colorDialog();}
        
        headerConfig.labelFontColour = window.prompt("Please choose a colour for the Label Font\n(Leave blank to select via Colour picker)",headerConfig.labelFontColour);
        if (headerConfig.labelFontColour=="") {headerConfig.labelFontColour = colorDialog();}
        headerConfig.labelOpacity = window.prompt("Please set opacity for Label background\n(Default 255)",headerConfig.labelOpacity);
        headerConfig.labelOutlineOpacity = window.prompt("Please set opacity for Label border\n(Default 255)", headerConfig.labelOutlineOpacity);

        headerConfig.noteFillColour = window.prompt("Please choose a colour for the Note background\n(Leave blank to select via Colour picker)",headerConfig.noteFillColour);
        if (headerConfig.noteFillColour=="") {headerConfig.noteFillColour = colorDialog();}
        
        headerConfig.noteFontColour = window.prompt("Please choose a colour for the Note Font\n(Leave blank to select via Colour picker)",headerConfig.noteFontColour);
        if (headerConfig.noteFontColour=="") {headerConfig.noteFontColour = colorDialog();}
        headerConfig.noteOpacity = window.prompt("Please set opacity for Note background\n(Default 255)",headerConfig.noteOpacity);
        headerConfig.noteOutlineOpacity = window.prompt("Please set opacity for Note border\n(Default 255)",headerConfig.noteOutlineOpacity);

        headerConfig.linkFillColour = window.prompt("Please choose a colour for the View Links background\n(Leave blank to select via Colour picker)",headerConfig.linkFillColour);
        if (headerConfig.linkFillColour=="") {headerConfig.linkFillColour = colorDialog();}

        headerConfig.linkFontColour = window.prompt("Please choose a colour for the View Links Font\n(Leave blank to select via Colour picker)",headerConfig.linkFontColour);
        if (headerConfig.linkFontColour=="") {headerConfig.linkFontColour = colorDialog();}
        headerConfig.linkOpacity = window.prompt("Please set opacity for Link background\n(Default 255)",headerConfig.linkOpacity);
        headerConfig.linkOutlineOpacity = window.prompt("Please set opacity for Link border\n(Default 255)",headerConfig.linkOutlineOpacity);
    }

    $.fs.writeFile(__DIR__ + '.conf/header-conf.js', "const headerConfig="+JSON.stringify(headerConfig));
}

try {
    load(__DIR__ + '.conf/header-conf.js');
}
catch (e) {
    configWizard();
}

