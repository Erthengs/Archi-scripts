// Set up for creation of views/header/changelog
const gridSize = headerConfig.gridSize;
const linkHeight = gridSize * headerConfig.linkHeight;
const linkWidth = gridSize * 17;
const rowLimit = headerConfig.wide?8:4;
const rowPadding = headerConfig.wide?3:1;
const height = gridSize * 2;
const labelWidth = gridSize * 10;

let theSystem = Java.type("java.lang.System");
var currentDate = new Date().toISOString().slice(0, 10);
var archimateView = selection.filter("archimate-diagram-model").first();

switch(""+buttonDialog("What do you want to do?", ["Create View", "Update View", "Manage Config", "Manage View Links", "Commit"])) {
case "1":
	theOption="New";
    break;
case "2":
	theOption="Update";
    if (!archimateView) {
        console.error("Please select a view to update.");
        exit();
    }
    break;
case "3":
    configWizard();
    exit();
    break;
case "4":
	theOption="onlyViewRefs";
    break;
case "5":
	var logName= theSystem.getProperty("user.name") + " - Changelog";
	var theChangeLog = $("archimate-diagram-model."+logName).first();
	if (theChangeLog) {
		setClipboardString(theChangeLog.documentation || "");
		theChangeLog.documentation = "";
	} else {
		setClipboardString("");
	}
	console.log("commit")
    exit();
default:
    console.log("Cancel");
    exit();
}

function sortObj (obj1, obj2) {
    if (obj1.name>obj2.name) return 1;
    if (obj1.name<obj2.name) return -1;
    return 0;
}

function buildTree(thisFolder, theParent, theSelectedViews){
    var theFolders = [];
    $(thisFolder).children("folder").forEach(function(folder){
        theFolders.push(folder);
    });
    var theSortedFolders = theFolders.sort(sortObj);
    theSortedFolders.forEach(function (folder){
        let theFolder = new TreeItem(theParent,0);
        theFolder.setText(folder.name);
        buildTree(folder, theFolder, theSelectedViews);
        theFolder.setExpanded(true);
    })
    var theViews = [];
    $(thisFolder).children("view").forEach(function(view){
        theViews.push(view);
    });
    var theSortedViews = theViews.sort(sortObj);
    theSortedViews.forEach(function (view){
        let theChild = new TreeItem(theParent,0);
        theChild.setText(view.name);
        theChild.setData("id",view.id);
        if ($(theSelectedViews).children("."+view.name).first()!=null) {
            theChild.setChecked(true);
        }
    })
}

function getChecked(item, parentChecked){
    var checked = "";
    var children = item.getItems();
    if (!parentChecked) {
        parentChecked = item.getChecked();
    }
    if (children.length>0)
    {   
        for (var count=0; count<children.length; count++) {
            checked += getChecked(children[count], parentChecked);
        }
    }
    else {
        if (parentChecked||item.getChecked()) {
            checked += ","+item.getData("id");
        }
    }
    return checked;
}

function getSelectedViews(theView) {
    theLinkGroup = $(theView).children("diagram-model-group.Links").first();
    return theLinkGroup;
}

function getDigits(num) {
    return num<10?"0"+num:""+num;
}

let cfgDialog = {

    /**
     * Default values
     */
    config: {
        author: theSystem.getProperty("user.name"),
        createdDate: archimateView!=null && archimateView.prop("Created_on")!=null?archimateView.prop("Created_on"):currentDate.toString(),
        version: archimateView!=null && archimateView.prop("Version")!=null?parseInt(archimateView.prop("Version"))+1:1,
        editor: theSystem.getProperty("user.name"),
        updatedDate: currentDate.toString(),
        name: archimateView!=null?archimateView.name:"",
        documentation: (archimateView!=null && archimateView.documentation)?archimateView.documentation:"",
        logoLink: false,
		hideFromExport: archimateView!=null?(archimateView.prop("_hide_from_export_")!=null?archimateView.prop("_hide_from_export_"):false):false,
        selectedViews: ""
    },
    widgets: {},
    /**
     * Helper to create a widget
     * 
     * @param {string} name - The widget name
     * @param {JavaClass} widgetClass - the Java widget class
     * @param {JavaObject} c - The container
     * @param {string} label - the label if any for the widget. A Label widget will be created if necessary
     * @param {(...a: any) => void} init - a function to finalize initialisation (value, etc )
     */
    createWidget: function (name, widgetClass, c, label, init, flags = SWT.BORDER) {
        if (label != null) {
            let txt = new LabelWidget(c, SWT.NONE);
            txt.setText(label);
            GridDataFactory.fillDefaults().align(SWT.LEFT, SWT.TOP).applyTo(txt);
        }
        let widget = new widgetClass(c, flags);
        if (init != null) init(widget);
        // saving in widgets reference array
        if (name != null) this.widgets[name] = widget;
    },
    /**
     * as open() will destroy the widgets on close, saving values to config
     */
    saveInput: function (option) {

        switch (option) {
            case "New":
				this.config.version = parseInt(this.widgets.spinVersion.getText(), 10);
				this.config.name = this.widgets.textName.getText();
				this.config.documentation = this.widgets.textDocumentation.getText();
				this.config.hideFromExport = this.widgets.checkboxHideReport.getSelection();
				this.config.author = this.widgets.textAuthor.getText();
		        this.config.createdDate = this.widgets.dateCreatedDate.getYear() + "-"+getDigits(this.widgets.dateCreatedDate.getMonth()+1) +"-"+getDigits(this.widgets.dateCreatedDate.getDay());
                if (this.config.author=="") {return false}
                break;
            case "Update":
				this.config.version = parseInt(this.widgets.spinVersion.getText(), 10);
				this.config.name = this.widgets.textName.getText();
				this.config.documentation = this.widgets.textDocumentation.getText();
				this.config.hideFromExport = this.widgets.checkboxHideReport.getSelection();
                this.config.editor = this.widgets.textEditor.getText();
		        this.config.updatedDate = this.widgets.dateUpdatedDate.getYear() + "-"+getDigits(this.widgets.dateUpdatedDate.getMonth()+1) +"-"+getDigits(this.widgets.dateUpdatedDate.getDay());
                this.config.changelog = this.widgets.textChangelog.getText();
                if (this.config.changelog=="") {return false}
                if (this.config.editor=="") {return false}
                break;
			case "onlyViewRefs":
				this.config.logoLink = this.widgets.checkboxLogolink.getSelection();
                break;
        }

        var allItems = this.widgets.viewTreeWidget.getItems();

        for (var i=0; i< allItems.length; i++) {
            this.config.selectedViews = getChecked(allItems[i],false);
        }
        if (this.config.selectedViews!="") {this.config.selectedViews=this.config.selectedViews.substring(1)}

        // Basic validation
        if (this.config.name=="") {return false}
        if (this.config.documentation=="") {return false}
        return true;
    },

    open: function(option) {
        switch (option) {
            case "New":
                return (this.newDialog.open() == 0)  // OK = 0, Cancel = 1, Closed = -1
            case "Update":
                return (this.updateDialog.open() == 0)  // OK = 0, Cancel = 1, Closed = -1
			case "onlyViewRefs":							
                return (this.updateViewRefs.open() == 0)  // OK = 0, Cancel = 1, Closed = -1
        }
        
    },

    // NB: Nashorn specific JS syntax! (like java anonymous function)
    // also not possible to define anything else than inherited method to override. No new method, no property
	//--------------------------------------------------------------------------------------------------------------------------------
	updateViewRefs: new ConfigDialog(shell) {

        create: function () {
            Java.super(cfgDialog.updateViewRefs).create();
            cfgDialog.updateViewRefs.setTitle("Change View References");
            cfgDialog.updateViewRefs.setMessage("Please provide the following details", IMessageProvider.WARNING);
        },

        createDialogArea: function (parent) {
            
            var cfg = cfgDialog.config;
            let area = Java.super(cfgDialog.updateViewRefs).createDialogArea(parent);
            
			// the area contains an horizontal sep, and a grid layout
            let container = new CompositeWidget(area, SWT.NONE);
            GridDataFactory.swtDefaults().align(SWT.FILL, SWT.BEGINNING).hint(800,700).applyTo(container);
            GridLayoutFactory.swtDefaults().numColumns(2).margins(10,10).spacing(10, 5).applyTo(container);

				                
            cfgDialog.createWidget('viewTreeWidget', TreeWidget, container, "Views", 
                (tree) => {
                    var theSelectedViews = getSelectedViews(archimateView);
                    $("folder.Views").forEach(function (folder){
                        let theParent = new TreeItem(tree,0);
                        theParent.setText(folder.name);
                        buildTree(folder, theParent,theSelectedViews);
                        theParent.setExpanded(true);
                    })
                    //tree.setItems($("view"));
                    GridDataFactory.fillDefaults().hint(550,550).align(SWT.END, SWT.CENTER).applyTo(tree)
                },SWT.CHECK |SWT.MULTI | SWT.BORDER | SWT.V_SCROLL | SWT.H_SCROLL)
            cfgDialog.createWidget("checkboxLogolink", ButtonWidget, container, "Link on logo (select 1 view)",
            (w) => {
                w.setSelection(cfg.logoLink);
            }, SWT.CHECK);
           return area
        },
        
        okPressed: function() {
            if (cfgDialog.saveInput("onlyViewRefs")) {
                Java.super(cfgDialog.updateViewRefs).okPressed();
            }
        }
    },
	//---------------------------------------------------------------------------------------------------------------    
	
	
	
	updateDialog: new ConfigDialog(shell) {

        create: function () {
            Java.super(cfgDialog.updateDialog).create();
            cfgDialog.updateDialog.setTitle("Update View");
            cfgDialog.updateDialog.setMessage("Please provide the following details", IMessageProvider.WARNING);
        },

        createDialogArea: function (parent) {
            
            var cfg = cfgDialog.config;
            let area = Java.super(cfgDialog.updateDialog).createDialogArea(parent);
            
			// the area contains an horizontal sep, and a grid layout
            let container = new CompositeWidget(area, SWT.NONE);
            GridDataFactory.swtDefaults().align(SWT.FILL, SWT.BEGINNING).hint(800,725).applyTo(container);
            GridLayoutFactory.swtDefaults().numColumns(4).margins(10,10).spacing(10, 5).applyTo(container);

            let group = new GroupWidget(container, SWT.NONE);
            GridDataFactory.swtDefaults().span(4,1).grab(true, false).align(SWT.FILL, SWT.FILL).applyTo(group);
            GridLayoutFactory.swtDefaults().numColumns(2).applyTo(group);
            group.setText("General info");
            //Name
            cfgDialog.createWidget('textName', TextWidget, group, "Name *", 
                (w) => {
                    w.setText(cfg.name);
                    GridDataFactory.fillDefaults().align(SWT.FILL, SWT.END).grab(true,false).applyTo(w);
                });
            //Documentation
            cfgDialog.createWidget('textDocumentation', TextWidget, group, "Purpose *", 
            (w) => {
                w.setText(cfg.documentation);
                GridDataFactory.fillDefaults().align(SWT.FILL, SWT.END).hint(50,50).grab(true,false).applyTo(w);
            },SWT.MULTI|SWT.BORDER|SWT.WRAP|SWT.V_SCROLL);

/// new group2 
            let group2 = new GroupWidget(container, SWT.NONE);
            GridDataFactory.swtDefaults().span(4,1).grab(true, false).align(SWT.FILL, SWT.FILL).applyTo(group2);
            GridLayoutFactory.swtDefaults().numColumns(4).applyTo(group2);
            group2.setText("Details");
			// Editor
            cfgDialog.createWidget('textEditor', TextWidget, group2, "Editor *", 
                (w) => {
                    w.setText(cfg.editor);
                    GridDataFactory.fillDefaults().align(SWT.FILL, SWT.END).grab(true, false).applyTo(w);
                });

						// last updated on
            cfgDialog.createWidget('dateUpdatedDate', DateTimeWidget, group2, "         Updated date", 
                (w) => {
                    var dateArray = cfg.updatedDate.split("-");
                    w.setDate(parseInt(dateArray[0]),parseInt(dateArray[1])-1,parseInt(dateArray[2]));
                    GridDataFactory.fillDefaults().align(SWT.FILL, SWT.END).applyTo(w);
                });
				
            // Version section
            cfgDialog.createWidget('spinVersion', SpinnerWidget, group2, "Version nr   ", 
                (w) => {
                    w.setValues(cfg.version, 1, 200, 0, 1, 10);
                    GridDataFactory.fillDefaults().hint(10,20).grab(true,false).applyTo(w);
                });
				
						// checkbox hide from export
            cfgDialog.createWidget("checkboxHideReport", ButtonWidget, group2, "         Hide from export?                      ",
            (w) => {
                w.setSelection(false);
            }, SWT.CHECK),
				
				
            cfgDialog.createWidget('textChangelog', TextWidget, group, "Changelog *", 
            (w) => {
                w.setText("");
                GridDataFactory.fillDefaults().align(SWT.FILL, SWT.END).hint(50,50).grab(true,false).applyTo(w);
            },SWT.MULTI|SWT.BORDER|SWT.WRAP|SWT.V_SCROLL);
                    

				

                
            cfgDialog.createWidget('viewTreeWidget', TreeWidget, container, "Linked Views", 
                (tree) => {
                    var theSelectedViews = getSelectedViews(archimateView);
                    $("folder.Views").forEach(function (folder){
                        let theParent = new TreeItem(tree,0);
                        theParent.setText(folder.name);
                        buildTree(folder, theParent,theSelectedViews);
                        theParent.setExpanded(true);
                    })
                    //tree.setItems($("view"));
                    GridDataFactory.fillDefaults().hint(675,350).align(SWT.END, SWT.CENTER).applyTo(tree)
                },SWT.CHECK |SWT.MULTI | SWT.BORDER | SWT.V_SCROLL | SWT.H_SCROLL);

            
           return area
        },
        
        okPressed: function() {
            if (cfgDialog.saveInput("Update")) {
                Java.super(cfgDialog.updateDialog).okPressed();
            }
        }
    },

