                    console.log(cfg.createdDate);
                    var dateArray = cfg.createdDate.split("-");
                    w.setDate(parseInt(dateArray[0]),parseInt(dateArray[1])-1,parseInt(dateArray[2]));
                    GridDataFactory.fillDefaults().align(SWT.FILL, SWT.END).applyTo(w);
                });


            // Version section
            cfgDialog.createWidget('spinVersion', SpinnerWidget, group2, "Version nr    ", 
                (w) => {
                    w.setValues(1, 1, 200, 0, 1, 10);
                    GridDataFactory.fillDefaults().hint(10,20).grab(true,false).applyTo(w);
                });

			// checkbox hide from export
            cfgDialog.createWidget("checkboxHideReport", ButtonWidget, group2, "         Hide from export?                      ",
            (w) => {
                w.setSelection(false);
            }, SWT.CHECK);


            cfgDialog.createWidget('viewTreeWidget', TreeWidget, container, "Linked Views", 
                (tree) => {
                    $("folder.Views").forEach(function (folder){
                        let theParent = new TreeItem(tree,0);
                        theParent.setText(folder.name);
                        buildTree(folder, theParent,null);
                        theParent.setExpanded(true);
                    })
                    //tree.setItems($("view"));
                    GridDataFactory.fillDefaults().hint(675,350).align(SWT.END, SWT.CENTER).applyTo(tree)
                },SWT.CHECK |SWT.MULTI | SWT.BORDER | SWT.V_SCROLL | SWT.H_SCROLL)

            
           return area
        },
        
        okPressed: function() {
            if (cfgDialog.saveInput("New")) {
                Java.super(cfgDialog.newDialog).okPressed();
            }
        }
    }
}

function manageDiagram(option) {
    console.log(option);
    console.log("Please Wait...")
    switch (option) {
        case "New":
            var OK = cfgDialog.open("New")
            console.log(OK, '=>\n', cfgDialog.config)
            if (OK) {newDiagram(cfgDialog.config);}
            break;
        case "Update":
            var OK = cfgDialog.open("Update")
            console.log(OK, '=>\n', cfgDialog.config)
            if (OK) {updateDiagram (cfgDialog.config);}
            break;
		 case "onlyViewRefs":
            var OK = cfgDialog.open("onlyViewRefs")
            console.log(OK, '=>\n', cfgDialog.config)
            if (OK) {updateViewRefs (cfgDialog.config);}
            break;
    }
}

//Update the selected view
function updateDiagram(config) {
    
    if (archimateView.name != config.name) {
        var viewName = config.name;        
        var existing = $("archimate-diagram-model."+viewName).first();
        while (existing) {
            viewName+="+";
            existing = $("archimate-diagram-model."+viewName).first();
        }
        archimateView.name=viewName;
    }
    archimateView.documentation = config.documentation;
    archimateView.prop("Version", String(config.version));
    archimateView.prop("Last_edited_by", config.editor);
    archimateView.prop("Last_updated", config.updatedDate);
    if (config.hideFromExport) {
        archimateView.prop("_hide_from_export_", ""+config.hideFromExport);
    }
    else {
        archimateView.removeProp("_hide_from_export_");
    }
    

    var offset = 0;
    if (headerConfig.showLogo) { offset = insertLogo(archimateView)+1;}
    if (config.selectedViews!="") { offset += insertReferences(archimateView,config.selectedViews, offset)+1} // ISSUE WITH OFFSET!
    createHeader(archimateView, offset);
    var theChange = "v"+config.version+" - "+config.updatedDate+" - "+config.editor+" - "+config.changelog;
    if (headerConfig.showChangelog) {createChangelog(archimateView, headerConfig.wide?75:1, headerConfig.wide?offset:offset+13, theChange)}
	
// -------------------------------------------------------------------------------------------	
	
	if (headerConfig.useCoarchi) {
	
		 var logName= theSystem.getProperty("user.name") + " - Changelog";
		 var theChangeLog = $("archimate-diagram-model."+logName).first();
		 
		 if(buttonDialog("Are you going to commit/publish now or later?", ["Commit Now", "Commit later"])=="1") {
		 			var currentLog = theChangeLog ? (theChangeLog.documentation || "") : "";
					setClipboardString(archimateView.name+" - "+theChange+"\n"+currentLog);
					if (theChangeLog) {
						theChangeLog.documentation = "";
					}
		  } else {
					updateGlobalLog(config.editor,archimateView.name, theChange)
		 }
	}
	
//-----------------------------------------------------------------------------------------------------------------------------------	
}

// Create a new view
function newDiagram(config) {
    
    var viewName = config.name;
    var existing = $("archimate-diagram-model."+viewName).first();
    while (existing) {
        viewName+="+";
        existing = $("archimate-diagram-model."+viewName).first();
    }
    var archimateView = model.createArchimateView(viewName);
    archimateView.documentation = config.documentation;
    archimateView.prop("Created_by", config.author);
    archimateView.prop("Created_on", config.createdDate);
    archimateView.prop("Version", String(config.version));
    if (config.hideFromExport) {
        archimateView.prop("_hide_from_export_", ""+config.hideFromExport);
    }

    var offset = 0;

    if (headerConfig.showLogo) { offset = insertLogo(archimateView)+1;}
    if (config.selectedViews!="") { offset += insertReferences(archimateView,config.selectedViews, offset)}
    createHeader(archimateView, offset);
    var theChange = "v"+config.version+" - "+config.createdDate+" - "+config.author+" - "+config.documentation;
    if (headerConfig.showChangelog) {createChangelog(archimateView, headerConfig.wide?75:1, headerConfig.wide?offset:offset+13, theChange)}
    //if (headerConfig.globalChangelog) {updateGlobalLog(config.author, archimateView.name, theChange)};
    //if (headerConfig.clipChangelog) {setClipboardString(archimateView.name+" - "+theChange)};
	// -------------------------------------------------------------------------------------------	
	
	if (headerConfig.useCoarchi) {
		 var logName= theSystem.getProperty("user.name") + " - Changelog";
		 var theChangeLog = $("archimate-diagram-model."+logName).first();
		 
		 if(buttonDialog("Are you going to commit/publish now or later?", ["Commit Now", "Commit later"])=="1") {
		 			var currentLog = theChangeLog ? (theChangeLog.documentation || "") : "";
					setClipboardString(archimateView.name+" - "+theChange+"\n"+currentLog);
					if (theChangeLog) {
						theChangeLog.documentation = "";
					}
		  } else {
					updateGlobalLog(config.editor,archimateView.name, theChange)
		 }
	}
	
//-----------------------------------------------------------------------------------------------------------------------------------	
	
	
	
}

function updateGlobalLog(theUser, theName, theChange) {
    var logName= theUser + " - Changelog";
    var theChangeLog = $("archimate-diagram-model."+logName).first();
    if (!theChangeLog) 
    {
        var changeLogFolder = $("folder.Changelogs").first();
        if (!changeLogFolder) {
            var changeLogFolder  = $("folder.Views").first().createFolder("Changelogs");
        }
        var theChangeLog = model.createArchimateView(logName, changeLogFolder);
        var noteDisplayLog = theChangeLog.createObject("note", gridSize, gridSize, gridSize*100, gridSize*100);
        noteDisplayLog.labelExpression="$view{documentation}";
    }
    theChangeLog.documentation = theName+" - "+theChange +"\n"+ (theChangeLog.documentation || "")
}

//Regenerate the headers
function regenerateHeaders() {

}

function formatLabels (theLabels) {
    theLabels.forEach(function (label){
        label.borderType = BORDER.RECTANGLE;
        label.fontStyle = "bold";
        label.fillColor="#e8e8e8";
        if (headerConfig.customColours) {
            label.fillColor = headerConfig.labelFillColour;
            label.fontColor = headerConfig.labelFontColour;
            label.opacity = parseInt(headerConfig.labelOpacity);
            label.outlineOpacity = parseInt(headerConfig.labelOutlineOpacity);
        }
    });
}

function formatNotes (theNotes) {
    theNotes.forEach(function (note){
        note.borderType = BORDER.RECTANGLE;           
        if (headerConfig.customColours) {
            note.fillColor = headerConfig.noteFillColour;
            note.fontColor = headerConfig.noteFontColour;
            note.opacity = parseInt(headerConfig.noteOpacity);
            note.outlineOpacity = parseInt(headerConfig.noteOutlineOpacity);
        }
    });
}

function formatGroup (theGroup) {
    theGroup.borderType = BORDER.RECTANGLE;
    if (headerConfig.customColours) {
        theGroup.fillColor = headerConfig.groupFillColour;
        theGroup.opacity = parseInt(headerConfig.groupOpacity);
        theGroup.outlineOpacity = parseInt(headerConfig.groupOutlineOpacity);
    }
}

function createHeader(theView, offset) {
    
    var theGroup = $(theView).children("diagram-model-group.Header")

    if (theGroup.length<1) {
        var theLabels = [];
        var theNotes = [];
		offset = offset + 0.4
        var header_group = theView.createObject("group", gridSize, (offset+1)*gridSize, gridSize*73+1, gridSize*10+1);
        header_group.name = "Header";
        header_group.labelExpression = " ";
        formatGroup(header_group);



        var label_diagram = theView.createObject("note", gridSize*2, (offset+2)*gridSize, labelWidth, height, true);
        
        label_diagram.text = "View Name:";
        theLabels.push(label_diagram);

        var note_diagram = theView.createObject("note", labelWidth+gridSize*2 , (offset+2)*gridSize, gridSize*43, height,true);
        note_diagram.labelExpression = "$view{name}";
        theNotes.push(note_diagram);

        var label_version = theView.createObject("note", gridSize*56, (offset+2)*gridSize, labelWidth, height, true);
        label_version.text = "Version:";
        theLabels.push(label_version);
        
        var note_version = theView.createObject("note", gridSize*66,(offset+2)*gridSize, gridSize*7, height,true);
        note_version.labelExpression = "$view{property:Version}";
        theNotes.push(note_version);

offset = offset + 0.2

        var label_created = theView.createObject("note", gridSize*2, (offset+2)*gridSize+height,  labelWidth, height, true);
        label_created.text = "Created by/on:";
        theLabels.push(label_created);

        var note_created = theView.createObject("note", labelWidth+gridSize*2, (offset+2)*gridSize+height, gridSize*25, height, true);
        note_created.labelExpression = "$view{property:Created_by} $view{property:Created_on}";
        theNotes.push(note_created);

        var label_updated = theView.createObject("note", labelWidth+gridSize*28, (offset+2)*gridSize+height, labelWidth, height,true);
        label_updated.text = "Last edited by/on:";
        theLabels.push(label_updated);

        var note_updated = theView.createObject("note", labelWidth*2+gridSize*28, (offset+2)*gridSize+height, gridSize*25, height,true);
        note_updated.labelExpression = "$view{property:Last_edited_by} $view{property:Last_updated}";
        theNotes.push(note_updated);

offset = offset + 0.2

        var label_description = theView.createObject("note", gridSize*2, (offset+2)*gridSize+height*2, labelWidth, height*2, true);
        label_description.text = "Description:";
        theLabels.push(label_description);
        //setLogo(label_description);

        var note_documentation = theView.createObject("note", labelWidth+gridSize*2, (offset+2)*gridSize+height*2, gridSize*61, height*2, true);
        note_documentation.labelExpression = "$view{documentation}";
        theNotes.push(note_documentation);

        formatLabels(theLabels);
        formatNotes(theNotes);
    }
    else {
        theGroup.first().bounds={x:gridSize, y:offset*gridSize, width:gridSize*73+1, height:gridSize*10+1};
        formatGroup(theGroup);
    }
   
}

function createChangelog(theView, xOffset, yOffset, change) {

    var theChangeGroup = $(theView).children("diagram-model-group.Changelog")

    if (theChangeGroup.length<1) {
        var header_group = theView.createObject("group", xOffset*gridSize , (yOffset+1)*gridSize , gridSize*73+1, gridSize*10+1);
        header_group.name = "Changelog";
        formatGroup(header_group);

        var note_changelog = theView.createObject("note", (xOffset+1)*gridSize, (yOffset+3)*gridSize, gridSize*71, gridSize*7, true);
        note_changelog.text = change;
        formatNotes([note_changelog]);
    }
    else {
        theChangeGroup.first().bounds={x:xOffset*gridSize, y:(yOffset)*gridSize, width:gridSize*73+1, height:gridSize*10+1}
        formatGroup(theChangeGroup);
        note_changelog = theChangeGroup.children("diagram-model-note").first();
        note_changelog.text = change + "\n---\n"+note_changelog.text;
    }

    
}

function insertLogo(theView){
    var theGroup = $(theView).children("diagram-model-group.Logo")
    if (theGroup.length<1) {      
        var logoGroup = theView.createObject("group", gridSize, gridSize, (linkWidth)+(gridSize*2)+1, (gridSize*5)+1);
        //var logoGroup = theView.createObject("group", gridSize, gridSize, (linkWidth)+(gridSize*2)+100, (gridSize*5)+1);
        logoGroup.name="Logo";
        logoGroup.borderType = BORDER.RECTANGLE;
        logoGroup.outlineOpacity =0;
        logoGroup.labelExpression=" ";
        if (headerConfig.customColours) {
            logoGroup.fillColor = headerConfig.groupFillColour;
        }

        var theLogo = theView.createObject("note",gridSize, gridSize, (linkWidth)+(gridSize*2)+1, (gridSize*5)+1,true);
        theLogo.borderType = BORDER.NONE;
        setLogo(theLogo);
		
		var theLink2 = $("."+headerConfig.logoLink).filter("archimate-diagram-model").first();
		if (theLink2 ==null) {console.log("no diagram chosen")} else {
			var viewRef = theView.createViewReference(theLink2, gridSize, gridSize, (linkWidth)+(gridSize*2)+1, (gridSize*5)+1,true);
			viewRef.Opacity = 0;
			viewRef.outlineOpacity =0;
			viewRef.labelExpression=" ";
			viewRef.showIcon = SHOW_ICON.NEVER
		}
    }
    return 5;
}

function insertReferences(theView, theViews, offset) {

	var theGroup = $(theView).children("diagram-model-group.Links")
    var selected_views_array = theViews.toString().split(",");
    var selected_views_array_count = selected_views_array.length;
    var totalRows = Math.ceil(selected_views_array_count/rowLimit);
    

    var maxHeight= gridSize*(totalRows+1)+(linkHeight*totalRows);

    if (theGroup.length<1) {      
        var link_group = theView.createObject("group", gridSize, (offset+1)*gridSize, (rowLimit*linkWidth)+(gridSize*(rowLimit+rowPadding))+1, maxHeight+1);
        link_group.name = "Links";
        link_group.labelExpression = " ";
        formatGroup(link_group);
    }
    else {
        theGroup.first().bounds={x:gridSize, y:(offset+1)*gridSize, width:(rowLimit*linkWidth)+(gridSize*(rowLimit+rowPadding))+1, height:maxHeight+1};
        formatGroup(theGroup);
        theGroup.children().forEach(function (v){
            v.delete();
        });      
    }
    
    var rowCounter = 0;
    var row = 0;

    for (var j=0; j<selected_views_array_count;j++) {
        var theLink = $("#"+selected_views_array[j]).filter("archimate-diagram-model").first();
        if (rowCounter>=rowLimit) {
            row++
            rowCounter=0;
        }
        if (theLink.id!=theView.id) {
            var viewRef = theView.createViewReference(theLink, gridSize*(rowCounter+2)+(rowCounter*linkWidth), (offset)*gridSize+gridSize*2+(row*linkHeight)+(gridSize*row), linkWidth, linkHeight, true);
            viewRef.textPosition = TEXT_POSITION.CENTER;
            if (!headerConfig.showLinkIcons) {viewRef.showIcon = SHOW_ICON.NEVER};
            if (headerConfig.customColours) {
                viewRef.fillColor = headerConfig.linkFillColour;
                viewRef.fontColor = headerConfig.linkFontColour;
                viewRef.opacity = parseInt(headerConfig.linkOpacity);
                viewRef.outlineOpacity = parseInt(headerConfig.linkOutlineOpacity);
            }
            rowCounter++;
        }
    };
	return (maxHeight+gridSize)/gridSize;
}

/* borrowed from https://gist.github.com/RemcoSchellekensNS/c840313d9166ee2dde5be8b878c1668a */
function setClipboardString(string) {
	
    var Toolkit = Java.type("java.awt.Toolkit");
    var Transferable = Java.type("java.awt.datatransfer.StringSelection");

    try {
        var clipboard = Toolkit.getDefaultToolkit().getSystemClipboard();
        transferable =  new Transferable(string);
        
        clipboard.setContents(transferable, transferable);
    } 
    catch (e) {
        console.log("Failed copy string " + string + " to the clipboard due to exception: " + e);
    }
}

function setLogo(theElement) {
    theElement.imageSource = IMAGE_SOURCE.CUSTOM;
    theElement.image = model.createImage(headerConfig.logoFile);
    theElement.imagePosition = IMAGE_POSITION.MIDDLE_CENTRE;
}

//---------------------------------------------------------------------------------------------------------------------
//Update the selected view
function updateViewRefs(config) {

	
	if (config.logoLink) {
		var theViews = config.selectedViews
		var selected_views_array = theViews.toString().split(",");        

		headerConfig.logoLink = $("#"+selected_views_array[0]).filter("archimate-diagram-model").first().toString().substring(25)
		//console.log($("#"+selected_views_array[0]).filter("archimate-diagram-model").first());
        //headerConfig.logoLink = "RPA" //$(".Workflow").filter("archimate-diagram-model").first();		
		$.fs.writeFile(__DIR__ + '.conf/header-conf.js', "const headerConfig="+JSON.stringify(headerConfig));
	} else {
		var offset = 0;
		if (headerConfig.showLogo) { offset = insertLogo(archimateView)+1;}
		if (config.selectedViews!="") { offset += insertReferences(archimateView,config.selectedViews, offset)+1} 
		createHeader(archimateView, offset);
		var theChange = "v"+config.version+" - "+config.updatedDate+" - "+config.editor+" - "+config.changelog;
		if (headerConfig.showChangelog) {createChangelog(archimateView, headerConfig.wide?75:1, headerConfig.wide?offset:offset+13, theChange)}
	}	
 // 
}
